package com.java;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.net.URL;
import java.io.PrintWriter;

public class Source {
    private String urlString;
    private int score;
    private String author;

    public Source(String urlString) {
        this.urlString = urlString;
        this.score = 50; // Base score
        this.author = "Unknown";
    }

    // Main processing method
    public void process() {
        checkDomain();
        checkKeywords();
        checkHTTPS();
        extractAuthor();
        normalizeScore();
        saveIfFlagged();
    }

    // Domain-based scoring
    private void checkDomain() {
        try {
            URL url = new URL(urlString);
            String host = url.getHost();

            if (host.endsWith(".gov") || host.endsWith(".edu")) {
                score += 30;
            } else if (host.endsWith(".org")) {
                score += 10;
            } else if (host.endsWith(".net")) {
                score += 5;
            } else if (host.endsWith(".xyz") || host.endsWith(".click")) {
                score -= 20;
            }

        } catch (Exception e) {
            score -= 20;
        }
    }

    // Keyword scanning
    private void checkKeywords() {
        String[] flaggedWords = {"fake", "clickbait", "shocking", "free", "win", "urgent"};

        for (String word : flaggedWords) {
            if (urlString.toLowerCase().contains(word)) {
                score -= 5;
            }
        }
    }

    // HTTPS bonus
    private void checkHTTPS() {
        if (!urlString.startsWith("https://")) {
            score -= 20;
        }
    }

private void extractAuthor() {
    BufferedReader reader = null;

    try {
        URL url = new URL(urlString);
        reader = new BufferedReader(new InputStreamReader(url.openStream()));

        String line;
        int lineCount = 0;

        while ((line = reader.readLine()) != null && lineCount < 200) { // limit scan
            lineCount++;
            String lower = line.toLowerCase();

            // ✅ 1. META TAG (handles " and ')
            if (lower.contains("<meta") && lower.contains("author")) {
                int contentIndex = lower.indexOf("content");
                if (contentIndex != -1) {

                    // Find first quote (either " or ')
                    int start = line.indexOf("\"", contentIndex);
                    if (start == -1) {
                        start = line.indexOf("'", contentIndex);
                    }

                    if (start != -1) {
                        char quoteType = line.charAt(start);
                        int end = line.indexOf(quoteType, start + 1);

                        if (end != -1) {
                            author = line.substring(start + 1, end).trim();
                            break;
                        }
                    }
                }
            }

            // ✅ 2. STRICT "By Name" pattern
            String cleaned = line.replaceAll("<.*?>", "").trim();

            if (cleaned.length() > 3 && cleaned.length() < 60) {
                if (cleaned.toLowerCase().startsWith("by ")) {
                    String possibleAuthor = cleaned.substring(3).trim();

                    // Avoid junk like "By clicking here"
                    if (!possibleAuthor.toLowerCase().contains("click")
                            && !possibleAuthor.toLowerCase().contains("using")) {

                        author = possibleAuthor;
                        break;
                    }
                }
            }
        }

    } catch (Exception e) {
        author = "Could not retrieve";
    } finally {
        try {
            if (reader != null) reader.close();
        } catch (Exception e) {
            // ignore
        }
    }

    // ✅ Final cleanup
    if (author == null || author.equals("") || author.length() > 60) {
        author = "Unknown";
    }

    // ✅ OPTIONAL: add to score (highly recommended)
    if (!author.equals("Unknown") && !author.equals("Could not retrieve")) {
        score += 10;
    } else {
        score -= 5;
    }
}
    // Final fallback
    if (author == null || author.equals("") || author.length() > 100) {
        author = "Unknown";
    }
}

    // Keep score between 0–100
    private void normalizeScore() {
        if (score > 100) score = 100;
        if (score < 0) score = 0;
    }

    // Save low-credibility sites
    private void saveIfFlagged() {
        if (score < 50) {
            try {
                PrintWriter writer = new PrintWriter("flagged.txt");
                writer.println(urlString);
                writer.close();
            } catch (Exception e) {
                System.out.println("Could not save flagged site.");
            }
        }
    }

    // Getters
    public int getScore() {
        return score;
    }

    public String getAuthor() {
        return author;
    }
}
